# ══════════════════════════════════════════════════════════════════════════════
#  GraphPulse — Environment Variables
#  Copy to .env and fill in your values before running `make up`
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphpulse
POSTGRES_USER=graphpulse
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://graphpulse:changeme@localhost:5432/graphpulse

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=graphpulse.transactions
KAFKA_TOPIC_SCORES=graphpulse.scores
KAFKA_GROUP_ID=graphpulse-consumer

# ── MinIO (S3-compatible object store) ────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=graphpulse-data

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Kaggle (required for make download-ieee) ──────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Feast feature server ──────────────────────────────────────────────────────
FEAST_ONLINE_STORE_HOST=localhost
FEAST_ONLINE_STORE_PORT=6379

# ── Training device ───────────────────────────────────────────────────────────
# Options: cuda | cpu
DEVICE=cuda

# ── Logging & observability ───────────────────────────────────────────────────
LOG_LEVEL=INFO
# Leave blank to disable Sentry error reporting
SENTRY_DSN=

# ── Inference ─────────────────────────────────────────────────────────────────
# Decision boundary for binary fraud classification (0.0 – 1.0)
FRAUD_SCORE_THRESHOLD=0.5
